{
  "name": "uba-ims",
  "version": "1.0.0",
  "description": "User & Internship Management System with TypeScript, TypeORM, MySQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node app/src/services/server.ts",
    "build": "tsc",
    "start": "node dist/services/server.js",
    "typeorm": "node node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d app/src/config/db.ts -n CreateTables",
    "migration:run": "npm run typeorm -- migration:run -d app/src/config/db.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.12.0",
    "apollo-server-express": "^3.13.0",
    "body-parser": "^2.2.0",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "mysql2": "^3.14.1",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.19",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
